# MixTV environment example
# Copy to .env.local for local development and fill in real secrets.

# Public app branding
NEXT_PUBLIC_SITE_NAME=MixTV

# GitHub Actions cron target
# Set this to the public base URL of the deployed app, for example:
# https://mixtv.example.com
CRON_BASE_URL=

# Auth
# Required by NextAuth and the local login/account API.
# Generate a strong value, for example: openssl rand -base64 32
AUTH_SECRET=

# Local credentials login API (/api/login, /api/account)
USERNAME=
PASSWORD=

# Persistence backend
# Supported values:
# - redis: Node Redis TCP client. Suitable for local/server runtime use.
# - upstash: Redis REST client. Preferred for Edge/Worker-compatible routes.
STORAGE_TYPE=redis

# Node Redis TCP config, used when STORAGE_TYPE=redis.
# Examples:
# REDIS_URL=redis://127.0.0.1:6379
# REDIS_URL=rediss://default:password@host:port
REDIS_URL=

# Upstash Redis REST config, used when STORAGE_TYPE=upstash.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
