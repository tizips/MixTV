# Public app branding
NEXT_PUBLIC_SITE_NAME=MixTV

# Shared auth secret
# Required for NextAuth JWT/session signing.
AUTH_SECRET=

# Local credentials login API (/api/login, /api/account)
# Required by src/modules/auth/server/login-api-service.ts.
USERNAME=
PASSWORD=

# Storage backend for server-side persistence used by auth flows.
# Currently only `redis` is supported.
STORAGE_TYPE=redis

# Redis connection string for the configured storage backend.
# Required when STORAGE_TYPE=redis.
# Example: redis://localhost:6379
REDIS_URL=
